{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitHub Contributions Tracker Configuration",
  "description": "Configuration for tracking GitHub contributions across multiple accounts",
  "type": "object",
  "required": ["tokens"],
  "properties": {
    "tokens": {
      "type": "object",
      "description": "GitHub personal access tokens to track",
      "additionalProperties": {
        "type": "string",
        "description": "GitHub personal access token for this account (for rate limit distribution)",
        "pattern": "^(ghp_|gho_|ghs_|github_pat_)[a-zA-Z0-9]+$",
        "example": "ghp_exampleToken1234567890abcdef"
      }
    }
  },
  "import": {
    "type": "object",
    "description": "Import configuration settings",
    "properties": {
      "concurrency": {
        "type": "integer",
        "description": "Number of jobs to process per batch",
        "minimum": 1,
        "maximum": 100,
        "default": 10
      },
      "maxRetries": {
        "type": "integer",
        "description": "Maximum retry attempts per failed job",
        "minimum": 0,
        "maximum": 10,
        "default": 2
      },
      "pageSize": {
        "type": "integer",
        "description": "Number of items per page for GraphQL pagination",
        "minimum": 1,
        "maximum": 100,
        "default": 50
      },
      "rateLimitGracePeriod": {
        "type": "integer",
        "description": "Grace period in milliseconds added when waiting for rate limit reset",
        "minimum": 0,
        "default": 1000
      },
      "skip": {
        "type": "object",
        "description": "Skip certain organizations and repositories",
        "properties": {
          "organizations": {
            "type": "array",
            "description": "Organizations to skip",
            "items": {
              "type": "string",
              "description": "Organization to skip"
            }
          },
          "repositories": {
            "type": "array",
            "description": "Repositories to skip",
            "items": {
              "type": "string",
              "description": "Repository to skip"
            }
          }
        }
      }
    }
  }
}
